  "components": {
    "schemas": {
      "UpdateCategoryRequest": {
        "type": "object",
        "properties": {
          "categoryGroupId": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "maxLength": 100, "minLength": 0 }
        },
        "required": ["categoryGroupId", "name"]
      },
      "CategoryResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" },
          "categoryGroupId": { "type": "integer", "format": "int64" },
          "categoryGroupName": { "type": "string" }
        }
      },
      "UpdateCategoryGroupRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 100, "minLength": 0 }
        },
        "required": ["name"]
      },
      "CategoryGroupResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "name": { "type": "string" }
        }
      },
      "CreateCategoryRequest": {
        "type": "object",
        "properties": {
          "categoryGroupId": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "maxLength": 100, "minLength": 0 }
        },
        "required": ["categoryGroupId", "name"]
      },
      "CreateCategoryGroupRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 100, "minLength": 0 }
        },
        "required": ["name"]
      },
      "UpdatePostsRequest": {
        "type": "object",
        "properties": {
          "postIds": { "type": "array", "items": { "type": "string" } },
          "status": {
            "type": "string",
            "enum": ["DISCARDED", "NOT_PUBLISHED", "PUBLISHED", "ON_HOLD"]
          },
          "categoryIds": { "type": "array", "items": { "type": "string" } }
        }
      },
      "PostSearchCondition": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "maxLength": 2147483647,
            "minLength": 2
          },
          "categoryIds": { "type": "array", "items": { "type": "string" } },
          "sourceSiteName": { "type": "string" }
        }
      },
      "PostCategoryResponse": {
        "type": "object",
        "properties": {
          "groupName": { "type": "string" },
          "categoryName": { "type": "string" }
        }
      },
      "PostResponse": {
        "type": "object",
        "properties": {
          "postId": { "type": "integer", "format": "int64" },
          "title": { "type": "string" },
          "pubDate": { "type": "string", "format": "date-time" },
          "thumbnail": { "type": "string" },
          "url": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "categories": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PostCategoryResponse" }
          },
          "sourceSiteName": { "type": "string" },
          "language": { "type": "string", "enum": ["KO", "EN"] }
        }
      },
      "PostResponseList": {
        "type": "object",
        "properties": {
          "posts": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PostResponse" }
          },
          "hasNext": { "type": "boolean" },
          "nextPostId": { "type": "integer", "format": "int64" }
        }
      }
    }
  }
}
