    "/admin/posts": {
      "get": {
        "tags": ["2-1 Admin Posts"],
        "summary": "관리자 게시글 목록 조회",
        "operationId": "a1-post-list",
        "parameters": [
          {
            "name": "searchCondition",
            "in": "query",
            "required": true,
            "schema": { "$ref": "#/components/schemas/PostSearchCondition" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["DISCARDED", "NOT_PUBLISHED", "PUBLISHED", "ON_HOLD"]
            }
          },
          {
            "name": "lastPostId",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int64", "default": 20 }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["KO", "EN"] }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/PostResponseList" }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["2-1 Admin Posts"],
        "summary": "게시글 상태 변경",
